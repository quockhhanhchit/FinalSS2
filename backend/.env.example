PORT=5000
# Local setup: use DB_*
# Railway MySQL: backend now also accepts MYSQLHOST, MYSQLPORT, MYSQLUSER,
# MYSQLPASSWORD, MYSQLDATABASE / MYSQL_DATABASE automatically.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=budgetfit_db
DB_USER=root
DB_PASSWORD=your_db_password
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_client_id
# Optional: allow multiple Google client IDs separated by commas
# GOOGLE_CLIENT_IDS=prod_client_id,preview_client_id
APP_URL=http://localhost:5173
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=BudgetFit <your_email@gmail.com>
